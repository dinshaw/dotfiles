# This is the default .slate file.
# If no ~/.slate file exists this is the file that will be used.

bind tab:cmd switch

config defaultToCurrentScreen true
config nudgePercentOf screenSize
config resizePercentOf screenSize

alias mon-laptop      1680x1050
alias mon-thunderbolt 2560x1440

# Resize Bindings
bind m:ctrl;alt;cmd   move screenOriginX;screenOriginY screenSizeX;screenSizeY

# Push Bindings
bind right:ctrl;cmd  push right bar-resize:screenSizeX/2
bind left:ctrl;cmd   push left  bar-resize:screenSizeX/2

# Throw Bindings
bind right:ctrl;alt throw right resize
bind left:ctrl;alt  throw left  resize

# Layouts
layout laptop AFTER shell path:~/ 'osascript change_input.applescript "Dvorak"'
// layout laptop AFTER shell path:~/ 'osascript change_input.applescript "Dvorak"'

default laptop resolutions:${mon-laptop}
default laptopAndThunderbolt resolutions:${mon-laptop};${mon-thunderbolt}

layout laptopAndThunderbolt 'Mailplane 3' throw left resize
layout laptopAndThunderbolt 'Microsoft Outlook' throw left resize
layout laptopAndThunderbolt 'Terminal' throw left resize
layout laptopAndThunderbolt 'HipChat' push right bar-resize:screenSizeX/2 | throw left
layout laptopAndThunderbolt 'Google Chrome' push left bar-resize:screenSizeX/2 | throw right
layout laptopAndThunderbolt 'Sublime Text' push right bar-resize:screenSizeX/2 | throw right

layout laptop 'Mailplane 3' throw 0 resize
layout laptop 'Microsoft Outlook' throw 0 resize
layout laptop 'Terminal' throw 0 resize
layout laptop 'HipChat' push right bar-resize:screenSizeX/2
layout laptop 'Google Chrome' throw 0 resize
layout laptop 'Sublime Text' throw 0 resize
